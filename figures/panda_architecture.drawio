<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="fig1-panda-architecture">
    <mxGraphModel dx="800" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="560" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Header disclaimer -->
        <mxCell id="hdr" value="Conceptual schematic (not a measurement).&amp;nbsp; &lt;i&gt;C&lt;/i&gt; = output vocabulary / class count; &lt;i&gt;N&lt;/i&gt; = consumed lattice sites (full or retained)." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontColor=#64748B;fontSize=14;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1000" height="30" as="geometry" />
        </mxCell>

        <!-- Forward row -->
        <mxCell id="sites" value="&lt;b&gt;Lattice sites&lt;/b&gt;&lt;br&gt;full or retained&lt;br&gt;&lt;i&gt;N&lt;/i&gt; sites" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#64748B;fontColor=#334155;strokeWidth=1.5;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="40" y="155" width="190" height="90" as="geometry" />
        </mxCell>

        <mxCell id="hidden" value="&lt;b&gt;Joiner hidden states&lt;/b&gt;&lt;br&gt;&lt;i&gt;h&lt;sub&gt;i&lt;/sub&gt;&lt;/i&gt;&amp;nbsp;&amp;nbsp;[&lt;i&gt;N&lt;/i&gt;,&amp;nbsp;&lt;i&gt;H&lt;/i&gt;]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#64748B;fontColor=#334155;strokeWidth=1.5;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="310" y="155" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- PANDA boundary container -->
        <mxCell id="panda" value="PANDA selected-normalization boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDF4EE;strokeColor=#0F766E;strokeWidth=2;verticalAlign=top;fontColor=#0F766E;fontStyle=1;fontSize=17;container=1;pointerEvents=0;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="590" y="70" width="430" height="260" as="geometry" />
        </mxCell>

        <mxCell id="tilematrix" value="full [&lt;i&gt;N&lt;/i&gt;,&amp;nbsp;&lt;i&gt;C&lt;/i&gt;] logits — never persistent" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;fillColor=#FFFFFF;strokeColor=#94A3B8;fontColor=#64748B;fontSize=12;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="panda">
          <mxGeometry x="75" y="50" width="280" height="55" as="geometry" />
        </mxCell>
        <mxCell id="tilestrip" value="tile" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0F766E;strokeColor=#0F766E;fontColor=#FFFFFF;fontSize=11;verticalLabelPosition=top;verticalAlign=bottom;labelBackgroundColor=none;fontColor=#0F766E;" vertex="1" parent="panda">
          <mxGeometry x="195" y="50" width="30" height="55" as="geometry" />
        </mxCell>

        <mxCell id="fwdtext" value="&lt;b&gt;Forward:&lt;/b&gt; stream exact full-&lt;i&gt;C&lt;/i&gt; log&amp;nbsp;&lt;i&gt;Z&lt;sub&gt;i&lt;/sub&gt;&lt;/i&gt;; tap target &amp;amp; blank scores" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontColor=#334155;fontSize=14;whiteSpace=wrap;" vertex="1" parent="panda">
          <mxGeometry x="20" y="140" width="390" height="45" as="geometry" />
        </mxCell>
        <mxCell id="bwdtext" value="&lt;b&gt;Backward:&lt;/b&gt; compact DP adjoints induce full-softmax gradients over all &lt;i&gt;C&lt;/i&gt;, accumulated tile-locally" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontColor=#334155;fontSize=14;whiteSpace=wrap;" vertex="1" parent="panda">
          <mxGeometry x="20" y="190" width="390" height="55" as="geometry" />
        </mxCell>

        <!-- DP loss -->
        <mxCell id="dp" value="&lt;b&gt;Transducer DP loss&lt;/b&gt;&lt;br&gt;blank / target&lt;br&gt;emissions only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#64748B;fontColor=#334155;strokeWidth=1.5;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="1130" y="155" width="220" height="90" as="geometry" />
        </mxCell>

        <!-- Backward row -->
        <mxCell id="bw" value="&lt;b&gt;Tile-local backward&lt;/b&gt;&lt;br&gt;recompute logits per &lt;i&gt;C&lt;/i&gt;-tile; no persistent [&lt;i&gt;N&lt;/i&gt;,&amp;nbsp;&lt;i&gt;C&lt;/i&gt;] grad_logits" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7F2FF;strokeColor=#2563EB;fontColor=#1E40AF;strokeWidth=2;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="590" y="410" width="430" height="90" as="geometry" />
        </mxCell>

        <mxCell id="out" value="&lt;b&gt;Persistent gradients&lt;/b&gt;&lt;br&gt;∇&lt;i&gt;h&lt;sub&gt;i&lt;/sub&gt;&lt;/i&gt;,&amp;nbsp; ∇&lt;i&gt;W&lt;/i&gt;,&amp;nbsp; ∇&lt;i&gt;b&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2563EB;fontColor=#1E40AF;strokeWidth=1.5;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="1130" y="410" width="220" height="90" as="geometry" />
        </mxCell>

        <!-- Memory contrast panel -->
        <mxCell id="panel" value="Persistent [&lt;i&gt;N&lt;/i&gt;,&amp;nbsp;&lt;i&gt;C&lt;/i&gt;] memory below the interface" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;fontColor=#334155;strokeWidth=1.5;verticalAlign=top;fontSize=14;fontStyle=1;container=1;pointerEvents=0;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="40" y="390" width="460" height="130" as="geometry" />
        </mxCell>
        <mxCell id="rowred" value="Materialized baseline: [&lt;i&gt;N&lt;/i&gt;,&amp;nbsp;&lt;i&gt;C&lt;/i&gt;] logits + [&lt;i&gt;N&lt;/i&gt;,&amp;nbsp;&lt;i&gt;C&lt;/i&gt;] grad_logits persist" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontColor=#7F1D1D;fontSize=13;" vertex="1" parent="panel">
          <mxGeometry x="15" y="35" width="430" height="38" as="geometry" />
        </mxCell>
        <mxCell id="rowgreen" value="PANDA: transient &lt;i&gt;C&lt;/i&gt;-tile buffers only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDF4EE;strokeColor=#0F766E;fontColor=#0F766E;fontSize=13;" vertex="1" parent="panel">
          <mxGeometry x="15" y="80" width="430" height="38" as="geometry" />
        </mxCell>

        <!-- Forward edges -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#334155;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="sites" target="hidden">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#334155;strokeWidth=2;fontSize=14;fontColor=#334155;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="hidden" target="panda">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="selected&lt;br&gt;log-probs" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0F766E;strokeWidth=2.5;fontSize=14;fontColor=#0F766E;verticalLabelPosition=top;verticalAlign=bottom;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="panda" target="dp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Backward edges -->
        <mxCell id="e4" value="compact adjoints (δ&lt;sub&gt;target&lt;/sub&gt;, δ&lt;sub&gt;blank&lt;/sub&gt;)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563EB;strokeWidth=2;fontSize=14;fontColor=#2563EB;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="dp" target="bw">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1240" y="370" />
              <mxPoint x="912" y="370" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e5" value="transient tiles" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563EB;strokeWidth=2;fontSize=14;fontColor=#2563EB;exitX=0.25;exitY=0;exitDx=0;exitDy=0;entryX=0.25;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="bw" target="panda">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563EB;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="bw" target="out">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#94A3B8;strokeWidth=1.5;dashed=1;endArrow=none;startArrow=none;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="panel" target="bw">
